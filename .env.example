# Stripe keys — get them from dashboard.stripe.com → Developers → API keys
# Use sk_test_ / pk_test_ for sandbox, sk_live_ / pk_live_ for production
NUXT_STRIPE_SECRET_KEY=sk_test_...
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — get it from:
#   - Local dev: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#   - Production: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
NUXT_STRIPE_WEBHOOK_SECRET=whsec_...

# DatoCMS — get it from datocms.com → Project settings → API tokens
NUXT_PUBLIC_DATOCMS_TOKEN=...
